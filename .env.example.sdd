# .env - MCP Server Configuration
# DO NOT COMMIT THIS FILE - Add to .gitignore

# ===========================================
# Required for MCP Servers
# ===========================================

# GitHub Token (for repository access)
# Required scopes: repo, read:org
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ===========================================
# Optional - Confluence Integration
# ===========================================

# Confluence/Wiki API
# Get token from: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_API_TOKEN=your_confluence_token
CONFLUENCE_USER_EMAIL=your.email@company.com

# ===========================================
# Optional - Jira Integration
# ===========================================

# Jira API
# Get token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-company.atlassian.net
JIRA_API_TOKEN=your_jira_token
JIRA_USER_EMAIL=your.email@company.com

# ===========================================
# Optional - Database Access
# ===========================================

# Database URL (for schema access via postgres MCP)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ===========================================
# Optional - Spec Memory Server
# ===========================================

# Path to the SDD memory directory (used by spec-memory MCP server)
# Default: ./.specify/memory
SPEC_MEMORY_PATH=./.specify/memory

# ===========================================
# Optional - Web Search
# ===========================================

# Brave Search API Key (for web research)
# Get from: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here
